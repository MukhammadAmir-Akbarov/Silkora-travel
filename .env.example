# ── Site ──────────────────────────────────────────────────────────────
# Public URL — used for canonical, hreflang, sitemap, OpenGraph.
NEXT_PUBLIC_SITE_URL=https://silkora.uz
# Privacy-friendly analytics (Plausible). Leave empty to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── AI itinerary planner ──────────────────────────────────────────────
# Choose a backend. If unset, it is inferred: groq → anthropic → ollama → demo.
#   ollama    = free & local (great for dev)
#   groq      = free cloud key, works on the deployed site (recommended for prod)
#   anthropic = Claude (paid)
#   demo      = no AI, canned sample itinerary
AI_PROVIDER=

# ── Option A: Ollama (free, local) ────────────────────────────────────
# Install: https://ollama.com  →  `ollama pull qwen2.5:7b`
# Then locally set: AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ── Option B: Groq (free cloud key — works on Vercel) ──────────────────
# Get a free key at https://console.groq.com/keys (no card required).
# On Vercel set: AI_PROVIDER=groq  +  GROQ_API_KEY=...
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Option C: Anthropic Claude (paid) ─────────────────────────────────
ANTHROPIC_API_KEY=
# Default: claude-sonnet-4-6 · alts: claude-opus-4-8, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=

# Daily cap on live generations (cloud cost kill-switch). Beyond it → demo.
# Local Ollama is free and not capped. Default 500.
PLAN_DAILY_LIMIT=

# ── Lead delivery (Telegram recommended) ──────────────────────────────
# Telegram: create a bot via @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alternative notification: email via Resend (https://resend.com)
RESEND_API_KEY=
LEAD_EMAIL=

# Durable fallback sink — POSTs every lead as JSON (Google Apps Script,
# n8n, Zapier, Supabase fn) so no lead is ever lost if Telegram fails.
LEAD_FALLBACK_WEBHOOK=

# If nothing is set, leads are logged to the server console.
